{
  "name": "HLLStatslive",
  "version": "1.0.1",
  "description": "Overlay pour serveur FR Hell Let Loose par TontonCarotte",
  "author": "[CHM3] TontonCarotte",

  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },

   "build": {
    "appId": "fr.tontoncarotte.hllwidget",
    "productName": "HLL Widget",
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "[CHM3] TontonCarotte"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HLL Widget"
    }
  },
  "dependencies": {
    "winreg": "^1.2.5"
  },

  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
